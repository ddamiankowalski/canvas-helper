{
  "name": "@javascripthub/canvas-helper",
  "version": "2.0.0",
  "description": "Canvas utility tool for creating and drawing on HTML5 canvas",
  "main": "dist/index.js",
  "type": "module",
  "repository": "github:ddamiankowalski/canvas-helper",
  "types": "dist/types",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc && cp README.md dist/",
    "preview": "vite preview",
    "format": "prettier --write .",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm"
  },
  "author": "Damian Kowalski",
  "license": "ISC",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js"
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  }
}
